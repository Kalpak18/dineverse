# Leave empty in development — Vite proxy handles /api -> localhost:5000
# In production set this to your backend URL: https://your-api.example.com/api
VITE_API_URL=

# Required for split hosting (Vercel frontend + Render backend).
# Set to your Render backend URL so Socket.io connects to the right server.
# Without this, real-time features (live orders, notifications) will silently fail.
VITE_BACKEND_URL=

# Google Maps JavaScript API key (optional).
# If set: MapPage and MapPicker use Google Maps (satellite + search + geocoding).
# If absent/empty: all map UI is hidden; no other functionality is affected.
# Enable these APIs in Google Cloud Console: Maps JavaScript API, Places API, Geocoding API.
VITE_GOOGLE_MAPS_API_KEY=
