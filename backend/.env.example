# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Set to "false" only if your DB provider uses self-signed SSL (Render, Railway)
DB_SSL_REJECT_UNAUTHORIZED=true

# ─── Auth ─────────────────────────────────────────────────────
# MUST be at least 32 random characters — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32plus_char_random_string
JWT_EXPIRES_IN=24h

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CLIENT_URL=https://yourdomain.com

# ─── SMTP Email (OTP verification) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="DineVerse" <your_gmail@gmail.com>

# ─── AWS S3 (image uploads) ───────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET_NAME=your-s3-bucket-name
S3_PUBLIC_URL=https://your-s3-bucket-name.s3.ap-south-1.amazonaws.com

# ─── Razorpay (subscription payments) ────────────────────────
# Use live keys in production: rzp_live_...
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─── Gemini AI (menu photo import) ───────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Delivery webhook (optional) ─────────────────────────────
# HMAC secret shared with your delivery partner for webhook verification
DELIVERY_WEBHOOK_SECRET=your_delivery_webhook_secret

# ─── Admin setup (one-time use) ───────────────────────────────
# Set to "true" only when creating the first admin account, then remove it
ADMIN_SETUP_ENABLED=false
